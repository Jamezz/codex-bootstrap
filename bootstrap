#!/usr/bin/env python3
"""Launch the in-place Codex Bootstrap rewrite."""

from __future__ import annotations

import sys
from pathlib import Path


def main() -> int:
    repo_root = Path(__file__).resolve().parent
    sys.path.insert(0, str(repo_root))

    from tools.bootstrap.bootstrap import main as bootstrap_main

    return bootstrap_main(repo_root=repo_root)


if __name__ == "__main__":
    raise SystemExit(main())
