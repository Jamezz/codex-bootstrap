#!/bin/sh
set -eu

if [ "$#" -lt 2 ]; then
  echo "usage: scripts/agent-dotnet <dotnet-project-dir> <dotnet-args...>" >&2
  echo "example: scripts/agent-dotnet . test" >&2
  exit 2
fi

project_dir=$1
shift

project_root=$(CDPATH= cd "$project_dir" && pwd)

export DOTNET_CLI_HOME="${DOTNET_CLI_HOME:-$project_root/.dotnet}"
export DOTNET_CLI_TELEMETRY_OPTOUT="${DOTNET_CLI_TELEMETRY_OPTOUT:-1}"
export DOTNET_NOLOGO="${DOTNET_NOLOGO:-1}"
export DOTNET_SKIP_FIRST_TIME_EXPERIENCE="${DOTNET_SKIP_FIRST_TIME_EXPERIENCE:-1}"
export NUGET_PACKAGES="${NUGET_PACKAGES:-$project_root/.nuget/packages}"

mkdir -p "$DOTNET_CLI_HOME" "$NUGET_PACKAGES"
lock_dir="$DOTNET_CLI_HOME/agent-dotnet.lock"
lock_waits=0
while ! mkdir "$lock_dir" 2>/dev/null; do
  lock_waits=$((lock_waits + 1))
  if [ "$lock_waits" -ge 600 ]; then
    echo "scripts/agent-dotnet: timed out waiting for project dotnet lock: $lock_dir" >&2
    exit 2
  fi
  sleep 1
done

cleanup_lock() {
  rmdir "$lock_dir" 2>/dev/null || true
}

trap cleanup_lock EXIT INT TERM

cd "$project_root"

dotnet "$@"
