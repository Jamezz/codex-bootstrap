#!/bin/sh
set -eu

if [ "$#" -lt 2 ]; then
  echo "usage: scripts/agent-gradle <gradle-project-dir> <gradle-args...>" >&2
  echo "       scripts/agent-gradle <gradle-project-dir> --ps|--logs|--stop|--kill" >&2
  echo "example: scripts/agent-gradle . test" >&2
  exit 2
fi

project_dir=$1
shift

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd "$script_dir/.." && pwd)

case "${1:-}" in
  --ps|--logs|--stop|--kill)
    exec python3 "$repo_root/tools/supermeta-gradle/gradle.py" --project "$project_dir" "$@"
    ;;
  *)
    exec python3 "$repo_root/tools/supermeta-gradle/gradle.py" --project "$project_dir" -- "$@"
    ;;
esac
