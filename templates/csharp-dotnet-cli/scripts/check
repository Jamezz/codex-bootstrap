#!/bin/sh
set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
project_root=$(CDPATH= cd "$script_dir/.." && pwd)
cd "$project_root"

rules_script=tools/supermeta-rules/check.py
if [ ! -f "$rules_script" ]; then
  rules_script=../../tools/supermeta-rules/check.py
fi

agent_dotnet=scripts/agent-dotnet
if [ ! -f "$agent_dotnet" ]; then
  agent_dotnet=../../scripts/agent-dotnet
fi

python3 "$rules_script" --config supermeta-rules.json --root . --skip-callouts
"$agent_dotnet" . restore --locked-mode
"$agent_dotnet" . format CsharpDotnetCli.slnx --verify-no-changes --no-restore
"$agent_dotnet" . build CsharpDotnetCli.slnx --configuration Release --no-restore
"$agent_dotnet" . test CsharpDotnetCli.slnx --configuration Release --no-build
