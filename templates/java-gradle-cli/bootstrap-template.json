  "generatedDocs": {
    "summary": "This is a compact Java Gradle command-line project with tests, first-class runtime logging, agent notes, generated operations docs, and a deterministic verification path.",
    "runtime": "Gradle owns compilation, test execution, Checkstyle, and the application run task. Runtime logging uses SLF4J and Logback, defaults to quiet text logs on stderr, and supports JSON logs with `LOG_LEVEL` and `LOG_FORMAT`. Agent verification goes through `scripts/agent-gradle` so Gradle state, harness logging, and stuck-process recovery are predictable.",
