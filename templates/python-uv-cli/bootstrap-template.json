  "generatedDocs": {
    "summary": "This is a compact Python uv command-line project with tests, type checking, first-class runtime logging, agent notes, generated operations docs, and a deterministic verification path.",
    "runtime": "uv owns dependency resolution and command execution. Runtime logging uses Python's standard `logging` package, defaults to quiet text logs on stderr, and supports JSON logs with `LOG_LEVEL` and `LOG_FORMAT`. Ruff owns formatting and linting, mypy owns type checking, pytest owns behavior tests, and `scripts/check` ties the full agent verification path together.",
    "entrypoints": [
      "src/python_uv_cli/cli.py",
      "src/python_uv_cli/__main__.py",
      "src/python_uv_cli/logging_config.py",
      "pyproject.toml project.scripts"
    ],
    "sourceRoots": [
      "src/python_uv_cli",
      "tools/supermeta-rules"
    ],
    "testRoots": [
      "tests",
      "supermeta-rules.json"
    ],
    "verificationCommands": [
      "./scripts/check"
    ],
    "runCommands": [
      "uv run --no-editable python-uv-cli",
      "uv run --no-editable python-uv-cli \"Ada Lovelace\"",
      "uv run --no-editable python -m python_uv_cli \"Ada Lovelace\"",
      "LOG_LEVEL=info LOG_FORMAT=json uv run --no-editable python-uv-cli"
    ],
    "firstUsefulEdit": "Extend `src/python_uv_cli/cli.py`, update `tests/test_cli.py` first or in the same change, then rerun `./scripts/check`."
  },
