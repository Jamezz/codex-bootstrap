      "tools/supermeta-rules"
    ],
    "testRoots": [
      "src #[cfg(test)]",
      "supermeta-rules.json"
    ],
    "verificationCommands": [
      "./scripts/check"
    ],
    "runCommands": [
      "cargo run --quiet",
      "cargo run --quiet -- \"Ada Lovelace\"",
      "LOG_LEVEL=info LOG_FORMAT=json cargo run --quiet"
    ],
    "firstUsefulEdit": "Extend `src/cli.rs`, update the unit tests first or in the same change, then rerun `./scripts/check`."
  },
