  "generatedDocs": {
    "summary": "This is a compact Rust Cargo command-line project with tests, Clippy, rustfmt, first-class runtime logging, agent notes, generated operations docs, and a deterministic verification path.",
    "runtime": "Cargo owns compilation, test execution, formatting, linting, and runtime execution. Runtime logging is implemented in the starter with quiet text logs on stderr by default and JSON logs controlled by `LOG_LEVEL` and `LOG_FORMAT`. `scripts/check` ties Supermeta rules, rustfmt, Clippy, and tests into one agent verification path.",
    "entrypoints": [
      "src/main.rs",
      "src/cli.rs",
      "src/logging.rs",
      "Cargo.toml package.name"
    ],
    "sourceRoots": [
