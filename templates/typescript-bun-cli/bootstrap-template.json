  "generatedDocs": {
    "summary": "This is a compact TypeScript Bun command-line project with tests, type checking, first-class runtime logging, agent notes, generated operations docs, and a deterministic verification path.",
    "runtime": "Bun owns package installation, runtime execution, and tests. Runtime logging uses Pino, defaults to quiet text logs on stderr, and supports JSON logs with `LOG_LEVEL` and `LOG_FORMAT`. Biome owns formatting and linting, TypeScript owns static checking, and `scripts/check` ties the full agent verification path together.",
    "entrypoints": [
      "src/main.ts",
      "src/cli.ts",
      "src/logging.ts",
      "package.json scripts"
    ],
    "sourceRoots": ["src", "tools/supermeta-rules"],
    "testRoots": ["tests", "supermeta-rules.json"],
    "verificationCommands": ["./scripts/check"],
    "runCommands": [
      "bun run src/main.ts",
      "bun run src/main.ts \"Ada Lovelace\"",
      "LOG_LEVEL=info LOG_FORMAT=json bun run src/main.ts"
    ],
    "firstUsefulEdit": "Extend `src/cli.ts`, update `tests/cli.test.ts` first or in the same change, then rerun `./scripts/check`."
  },
