{
  "name": "typescript-bun-cli",
  "version": "0.1.0",
  "description": "A compact TypeScript Bun command-line starter.",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "./scripts/check",
    "format": "bun node_modules/@biomejs/biome/bin/biome check --write .",
    "lint": "bun node_modules/@biomejs/biome/bin/biome check .",
    "start": "bun run src/main.ts",
    "test": "bun test",
    "typecheck": "bun node_modules/typescript/lib/tsc.js --noEmit"
  },
  "bin": {
    "typescript-bun-cli": "./src/main.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.0"
  }
}
