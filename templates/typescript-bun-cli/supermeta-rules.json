{
  "line_count": [
    {
      "name": "product-source",
      "max_lines": 1000,
      "paths": ["src"],
      "include": ["**/*.ts"],
      "exclude": ["**/generated/**"]
    }
  ],
  "javascript_package_file_count": [
    {
      "name": "javascript-package-size",
      "max_files": 7,
      "paths": ["src", "tests"],
      "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
      "exclude": ["**/generated/**", "**/node_modules/**"]
    }
  ],
  "project_callouts": [
    {
      "name": "typescript-typecheck",
      "language": "typescript",
      "paths": ["src", "tests"],
      "include": ["**/*.ts"],
      "exclude": ["**/generated/**"],
      "command": ["bun", "run", "typecheck"]
    },
    {
      "name": "typescript-lint",
      "language": "typescript",
      "paths": ["src", "tests"],
      "include": ["**/*.ts"],
      "exclude": ["**/generated/**"],
      "command": ["bun", "run", "lint"]
    },
    {
      "name": "typescript-tests",
      "language": "typescript",
      "paths": ["src", "tests"],
      "include": ["**/*.ts"],
      "exclude": ["**/generated/**"],
      "command": ["bun", "test"]
    }
  ]
}
