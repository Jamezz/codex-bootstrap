{
  "name": "typescript-bun-mcp-server",
  "version": "0.1.0",
  "description": "A compact TypeScript Bun MCP server starter.",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "./scripts/check",
    "format": "bun node_modules/@biomejs/biome/bin/biome check --write .",
    "lint": "bun node_modules/@biomejs/biome/bin/biome check .",
    "start": "bun run src/main.ts",
    "test": "bun test",
    "typecheck": "bun node_modules/typescript/lib/tsc.js --noEmit"
  },
  "bin": {
    "typescript-bun-mcp-server": "./src/main.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.0"
  }
}
