#!/bin/sh
set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
project_root=$(CDPATH= cd "$script_dir/.." && pwd)
cd "$project_root"

rules_script=tools/supermeta-rules/check.py
if [ ! -f "$rules_script" ]; then
  rules_script=../../tools/supermeta-rules/check.py
fi

bun install --frozen-lockfile
python3 "$rules_script" --config supermeta-rules.json --root . --skip-callouts
bun run typecheck
bun run lint
bun test
